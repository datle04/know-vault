# App
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# Database (Neon dev branch)
DATABASE_URL=postgresql://user:password@ep-dev-xxx.neon.tech/knowvault?sslmode=require&pgbouncer=true
DIRECT_DATABASE_URL=postgresql://user:password@ep-dev-xxx.neon.tech/knowvault?sslmode=require

# Redis (Upstash dev instance)
REDIS_URL=redis://default:password@dev-xxx.upstash.io:6379

# JWT
JWT_ACCESS_SECRET=change-me-in-production
JWT_REFRESH_SECRET=change-me-in-production-different-from-access
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# AI Providers
GEMINI_API_KEY=your-gemini-api-key-here

